# 服务器配置
PORT=3001
NODE_ENV=development

# 数据库配置
DATABASE_URL=mysql://username:password@localhost:3306/brand_blacklist

# JWT配置
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_EXPIRES_IN=7d

# Redis配置（可选）
REDIS_URL=redis://localhost:6379

# 上传配置
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# 前端URL
FRONTEND_URL=http://localhost:3000

# 邮件配置（可选）
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=